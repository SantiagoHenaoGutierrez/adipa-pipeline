# Heavy Worker
HEAVY_WORKER_URL=http://heavy-worker:8000

# Pipeline Configuration
ALERT_THRESHOLD_PCT=5.0

# Logging
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
